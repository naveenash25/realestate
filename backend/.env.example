# Database
DATABASE_URL=postgres://realestate:realestate@localhost:5432/realestate

# Redis
REDIS_URL=redis://localhost:6379

# Auth (Keycloak — Google OAuth brokering)
BACKEND_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3001
KEYCLOAK_BASE_URL=http://localhost:8081
KEYCLOAK_REALM=realestate
KEYCLOAK_BACKEND_CLIENT_ID=realestate-backend
KEYCLOAK_BACKEND_CLIENT_SECRET=dev-local-secret-change-me
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret

# Auth (Twilio WhatsApp — sends OTP only; our own OtpService verifies)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_OTP_CONTENT_SID=

# App session (our own JWT, verified only by this backend)
SESSION_JWT_SECRET=replace-with-openssl-rand-base64-32
SESSION_JWT_TTL_SECONDS=604800

# Payments (Razorpay)
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# Notifications (MSG91)
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_SENDER_ID=RLEADS
MSG91_TEMPLATE_ID_LEAD=your-template-id

# WhatsApp Business API
WHATSAPP_BUSINESS_TOKEN=your-whatsapp-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# File storage — 'local' saves under backend/uploads/ (dev default, no setup
# needed). Set to 'gcs' once GCS_BUCKET_NAME/GCS_SERVICE_ACCOUNT_KEY point at
# a real bucket + service account key file.
STORAGE_DRIVER=local

# Google Cloud Storage (only used when STORAGE_DRIVER=gcs)
GCS_BUCKET_NAME=realestate-property-media
GCS_SERVICE_ACCOUNT_KEY=path/to/serviceaccount.json

# ML Service (Phase 2 — keep as stub for Phase 1)
ML_SERVICE_URL=http://stub

# App
NODE_ENV=development
PORT=8080

# Dev-mode auth bypass — active when NODE_ENV=development, or forced on in any
# non-production environment via AUTH_DISABLED=true (never honored when NODE_ENV=production).
AUTH_DISABLED=false
DEV_DEFAULT_USER_ID=a1000000-0000-4000-8000-000000000001
