# Database
DATABASE_URL=postgres://realestate:realestate@localhost:5432/realestate

# Redis
REDIS_URL=redis://localhost:6379

# Auth (Supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Payments (Razorpay)
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# Notifications (MSG91)
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_SENDER_ID=RLEADS
MSG91_TEMPLATE_ID_LEAD=your-template-id

# WhatsApp Business API
WHATSAPP_BUSINESS_TOKEN=your-whatsapp-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# Google Cloud Storage
GCS_BUCKET_NAME=realestate-property-media
GCS_SERVICE_ACCOUNT_KEY=path/to/serviceaccount.json

# ML Service (Phase 2 — keep as stub for Phase 1)
ML_SERVICE_URL=http://stub

# App
NODE_ENV=development
PORT=8080

# Dev-mode auth bypass (active only when NODE_ENV=development)
DEV_DEFAULT_USER_ID=b1000000-0000-4000-8000-000000000001
